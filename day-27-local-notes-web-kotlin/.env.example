# Local web server: only loopback hosts are accepted.
APP_HOST=127.0.0.1
APP_PORT=8787

# Local Ollama API: cloud URLs are rejected by the application.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_REQUEST_TIMEOUT_SECONDS=300
OLLAMA_KEEP_ALIVE=5m

# Upload limits. The server rejects files over either limit; it never truncates notes.
NOTES_MAX_UPLOAD_BYTES=1048576
NOTES_MAX_CHARS=24000
