# Public HTTPS entry point rendered by scripts/enable-public-https.sh only after
# every published A/AAAA address points to this VPS. The app and Ollama remain
# loopback-only; HTTP/3 is disabled so UDP 443 does not need to be exposed.
{
	servers {
		protocols h1 h2
		max_header_size 32KB

		timeouts {
			read_header 10s
			read_body 120s
			write 360s
			idle 2m
		}
	}
}

__PUBLIC_HOSTNAME__ {
	encode zstd gzip

	request_body {
		max_size 6MB
	}

	reverse_proxy 127.0.0.1:8787 {
		# Cheap process liveness only; dependency readiness is cached at /api/health.
		health_uri /api/health/live
		health_interval 30s
		health_timeout 5s
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}

	# Access logging is intentionally omitted so product names and session paths
	# are not persisted. Application logs must not contain request bodies or tokens.
}
