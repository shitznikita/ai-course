# Copy this file to /etc/cosmetics-ai/cosmetics-ai.env, set mode 0600,
# and replace the token. Never commit the populated file.
APP_HOST=127.0.0.1
APP_PORT=8787
APP_API_TOKEN=replace-with-at-least-32-random-characters
APP_ALLOW_INSECURE_NO_AUTH=false

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_QUEUE=2
OLLAMA_CONTEXT_LENGTH=8192
OLLAMA_REQUEST_TIMEOUT_SECONDS=300
OLLAMA_KEEP_ALIVE=30m
OLLAMA_MAX_OUTPUT_TOKENS=192

KNOWLEDGE_FILE=knowledge/ingredient-cards.json
SOURCES_FILE=knowledge/sources.json
PRODUCT_CATALOG_FILE=catalog/products.json
MAX_KNOWLEDGE_CARDS=12

OCR_COMMAND=tesseract
OCR_LANGUAGES=eng+rus
OCR_TIMEOUT_SECONDS=60

# Optional primary photo OCR. Keep disabled under the default loopback-only systemd policy.
# Enabling requires both provider reachability and a reviewed systemd egress drop-in.
ELIZA_VISION_ENABLED=false
ELIZA_VISION_API_URL=https://api.eliza.yandex.net/openrouter/v1/chat/completions
ELIZA_VISION_AUTH_SCHEME=OAuth
ELIZA_VISION_API_KEY=replace-with-eliza-oauth-token
ELIZA_VISION_MODEL=gpt-5-mini
ELIZA_VISION_TIMEOUT_SECONDS=90
ELIZA_VISION_MAX_COMPLETION_TOKENS=2000

MAX_PHOTO_BYTES=5242880
MAX_IMAGE_PIXELS=20000000

MAX_INCI_CHARS=12000
MAX_CHAT_CHARS=2000
MAX_CHAT_MESSAGES=8
MAX_CONTEXT_TOKENS=8192
MAX_SESSIONS=100
SESSION_TTL_MINUTES=30

RATE_LIMIT_REQUESTS=12
RATE_LIMIT_WINDOW_SECONDS=60
MAX_CONCURRENT_INFERENCE=1
INFERENCE_QUEUE_CAPACITY=2

# Read by the Gradle-generated application launcher.
JAVA_OPTS=-Xms256m -Xmx1024m
