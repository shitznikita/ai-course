# Web app stays on loopback. Use an SSH tunnel or a TLS reverse proxy.
APP_HOST=127.0.0.1
APP_PORT=8787

# For local development only. Deployment must use APP_API_TOKEN and false.
APP_ALLOW_INSECURE_NO_AUTH=true
APP_API_TOKEN=

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_REQUEST_TIMEOUT_SECONDS=300
OLLAMA_KEEP_ALIVE=30m
OLLAMA_CONTEXT_LENGTH=8192
OLLAMA_MAX_OUTPUT_TOKENS=192

KNOWLEDGE_FILE=knowledge/ingredient-cards.json
SOURCES_FILE=knowledge/sources.json
PRODUCT_CATALOG_FILE=catalog/products.json
MAX_KNOWLEDGE_CARDS=12

OCR_COMMAND=tesseract
OCR_LANGUAGES=eng+rus
OCR_TIMEOUT_SECONDS=60
MAX_PHOTO_BYTES=5242880
MAX_IMAGE_PIXELS=20000000

MAX_INCI_CHARS=12000
MAX_CHAT_CHARS=2000
MAX_CHAT_MESSAGES=8
MAX_CONTEXT_TOKENS=8192
MAX_SESSIONS=100
SESSION_TTL_MINUTES=30

RATE_LIMIT_REQUESTS=12
RATE_LIMIT_WINDOW_SECONDS=60
MAX_CONCURRENT_INFERENCE=1
INFERENCE_QUEUE_CAPACITY=2
