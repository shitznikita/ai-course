# Copy to .env for a local live review. Never commit the copied file.
LLM_API_KEY=replace-with-your-Eliza-OAuth-token
LLM_AUTH_SCHEME=OAuth
LLM_API_URL=https://api.eliza.yandex.net/openrouter/v1/chat/completions
LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# Local review limits. CI supplies GITHUB_REPOSITORY, PR_NUMBER, SHAs and
# GITHUB_TOKEN itself; these values only bound what can reach the model.
REVIEW_MAX_CHANGED_FILES=60
REVIEW_MAX_FILE_BYTES=120000
REVIEW_MAX_TOTAL_CHANGED_BYTES=600000
REVIEW_PROMPT_BYTES=55000
REVIEW_MAX_BATCHES=3
LLM_MAX_OUTPUT_TOKENS=1800
LLM_TIMEOUT_SECONDS=120

# Trusted-base RAG corpus and evidence budgets.
RAG_MAX_FILES=220
RAG_MAX_BYTES=2500000
RAG_MAX_FILE_BYTES=200000
RAG_MAX_CHUNKS=1200
RAG_CHUNK_LINES=60
RAG_EVIDENCE_BYTES=18000
