# Canonical project root. The default ".." is correct when the Gradle run task
# uses this module as its working directory.
PROJECT_ROOT=..

# The embedded MCP endpoint and Ollama must stay on loopback.
MCP_HOST=127.0.0.1
MCP_PORT=3031
MCP_TIMEOUT_SECONDS=15
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT_SECONDS=180
OLLAMA_CONTEXT_LENGTH=8192
OLLAMA_MAX_OUTPUT_TOKENS=384
# Reserved model-token slots for Ollama chat-template overhead and safety.
# Prompt UTF-8 bytes are conservatively capped by the remaining slots.
PROMPT_RESERVE_TOKENS=256

# "hash" is deterministic and offline. Use "ollama" only after pulling the
# embedding model.
EMBEDDING_BACKEND=hash
RAG_INDEX_FILE=runtime/rag-index.json
RAG_TOP_K=4
RAG_CANDIDATE_COUNT=10
RAG_MIN_RELEVANCE=0.18
RAG_CHUNK_MAX_TOKENS=260
MAX_DOCUMENT_BYTES=524288
MAX_CONTEXT_TOKENS=1800
MAX_FILE_LIST=80
