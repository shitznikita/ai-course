# Eliza/OpenRouter. Keep the real OAuth token only in .env or caller environment.
LLM_API_KEY=
LLM_AUTH_SCHEME=OAuth
# Pinned: live OAuth credentials are never sent to another destination.
LLM_API_URL=https://api.eliza.yandex.net/openrouter/v1/chat/completions
LLM_MODEL=meta-llama/llama-3.3-70b-instruct
LLM_CONNECT_TIMEOUT_SECONDS=10
LLM_REQUEST_TIMEOUT_SECONDS=45
LLM_MAX_RESPONSE_BYTES=131072
LLM_MAX_OUTPUT_TOKENS=700

# Loopback-only embedded MCP server.
MCP_HOST=127.0.0.1
MCP_PORT=3033
MCP_CONNECT_TIMEOUT_MILLIS=5000
MCP_REQUEST_TIMEOUT_MILLIS=10000

# Committed synthetic fixtures and local knowledge.
SUPPORT_FIXTURE_PATH=day-33-support-assistant-kotlin/fixtures/support-data.json
SUPPORT_KNOWLEDGE_DIR=day-33-support-assistant-kotlin/knowledge
SUPPORT_RAG_INDEX_PATH=day-33-support-assistant-kotlin/runtime/rag-index.json
SUPPORT_EVAL_PATH=day-33-support-assistant-kotlin/eval/scenarios.json

# Bounded RAG and prompt limits.
RAG_TOP_K=4
RAG_MIN_RELEVANCE=0.12
RAG_EMBEDDING_DIMENSIONS=192
RAG_MAX_CHUNK_CHARS=1800
RAG_MAX_EVIDENCE_CHARS=5200
PROMPT_MAX_CHARS=12000
QUESTION_MAX_CHARS=500
CHAT_HISTORY_TURNS=4
