MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=3019
MCP_CLIENT_NAME=ai-course-day-19-pipeline-agent
MCP_TIMEOUT_SECONDS=120

TELEGRAM_BACKEND=fixture
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace-with-telegram-api-hash
TELEGRAM_PHONE=+10000000000
TELEGRAM_CHAT=fixture-course-chat
TELEGRAM_LIMIT=100
TELEGRAM_RESEND_CODE=false
TELEGRAM_QR_WAIT_SECONDS=180
TDLIB_LIBRARY_PATH=/absolute/path/to/libtdjson.dylib

COURSE_DAY=auto
STATE_DIR=state
PIPELINE_REQUEST=Найди обсуждение задания дня курса в Telegram, сделай итог и execution prompt, затем сохрани результат в файл.
PIPELINE_MAX_STEPS=3

LLM_API_KEY=replace-with-oauth-token
LLM_AUTH_SCHEME=OAuth
LLM_API_URL=https://api.eliza.yandex.net/openrouter/v1/chat/completions
LLM_MODEL=meta-llama/llama-3.3-70b-instruct
