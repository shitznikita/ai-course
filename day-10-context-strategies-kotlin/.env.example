# Day 10 reuses the same Eliza token as Day 1.
# Keep the real file named .env and never commit it.
LLM_API_KEY=your_eliza_oauth_token_here
LLM_AUTH_SCHEME=OAuth
LLM_API_URL=https://api.eliza.yandex.net/openrouter/v1/chat/completions
LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# Agent/context settings.
AGENT_DEBUG=false
RECENT_MESSAGES_LIMIT=6
CONTEXT_STATE_FILE=context-state.json
FACTS_UPDATE_MODE=llm

# Optional cost settings in USD per 1M tokens.
# If empty, the program prints API usage/cost when provider returns it, or "unknown".
MODEL_INPUT_PRICE_PER_1M_TOKENS=
MODEL_OUTPUT_PRICE_PER_1M_TOKENS=
