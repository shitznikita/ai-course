# Day 8 reuses the same Eliza token as Day 1.
# Keep the real file named .env and never commit it.
LLM_API_KEY=your_eliza_oauth_token_here
LLM_AUTH_SCHEME=OAuth
LLM_API_URL=https://api.eliza.yandex.net/openrouter/v1/chat/completions
LLM_MODEL=meta-llama/llama-3.3-70b-instruct
AGENT_DEBUG=false
AGENT_HISTORY_FILE=token-agent-history.json

# Token/cost demo settings.
# Prices are optional because internal Eliza quota pricing can differ from public provider prices.
# If you know the exact price, set it in USD per 1M tokens.
MODEL_INPUT_PRICE_PER_1M_TOKENS=
MODEL_OUTPUT_PRICE_PER_1M_TOKENS=
MODEL_CONTEXT_WINDOW_TOKENS=131072
APP_CONTEXT_LIMIT_TOKENS=3000

# Big context dry-run/send settings.
BIG_CONTEXT_FILE=/Users/shitznikita/Downloads/skills-all.md
CONFIRM_BIG_CONTEXT_SEND=
