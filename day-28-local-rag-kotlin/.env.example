# Reuse the real Week 6 index built by Day 21. The file is a local runtime artifact, not Git content.
WEEK6_INDEX_FILE=../day-21-document-indexing-kotlin/index/structured-index.json

# Only a local Ollama HTTP URL is accepted for both embedding and generation.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT_SECONDS=300
OLLAMA_KEEP_ALIVE=5m

RETRIEVAL_TOP_K=4
RAG_MAX_CONTEXT_TOKENS=2200
BENCHMARK_QUESTIONS_FILE=eval/benchmark-questions.json
BENCHMARK_RUNS=3
REPORTS_DIR=reports

# Required by compare and benchmark. run-local-rag.sh also reads Day 1's local .env if present.
LLM_API_KEY=replace-with-oauth-token
LLM_AUTH_SCHEME=OAuth
LLM_API_URL=https://api.eliza.yandex.net/openrouter/v1/chat/completions
LLM_MODEL=meta-llama/llama-3.3-70b-instruct
# Optional only for cloud models that support it; otherwise use provider default.
# CLOUD_TEMPERATURE=0
CLOUD_REQUEST_TIMEOUT_SECONDS=300
